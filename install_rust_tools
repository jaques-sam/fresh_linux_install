#!/usr/bin/env bash
# shellcheck source=/dev/null
# shellcheck disable=SC2016

source install_helpers.sh
print_commence "$BASH_SOURCE"

function __install_rust() {
  is_installed cargo && return

  echo -e "\nInstalling rust"
  curl https://sh.rustup.rs -sSf | sh
  echo 'source "$HOME/.cargo/env"' >> "$HOME/.zshenv"
  source "$HOME/.zshenv"
}

__install_rust

[[ -d "$HOME/.cargo" ]] && source "$HOME/.cargo/env"

cargo install \
  bat \
  du-dust \
  exa \
  fastmod \
  fd-find \
  ripgrep \
  procs \
  rm-improved \
  sd \
  starship \
  tokei \
  topgrade \
  xcp \
  zoxide \
  cargo-audit \
  --locked

rustup component add \
  clippy \
  rustfmt

command -v starship > /dev/null && echo 'eval "$(starship init zsh)"' >> "$HOME/.zshrc"
command -v zoxide > /dev/null && echo 'eval "$(zoxide init zsh)"' >> "$HOME/.zshrc"
