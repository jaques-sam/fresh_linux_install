#!/usr/bin/env bash
# shellcheck source=/dev/null
# shellcheck disable=SC2016

source install_helpers.sh
print_commence "$BASH_SOURCE"

function __install_rust() {
  is_installed cargo && return

  echo -e "\nInstalling rust"
  curl https://sh.rustup.rs -sSf | sh

  update_dot_file cargo_config.toml "$HOME/.cargo/config.toml"

  [[ -d "$HOME/.cargo" ]] && source "$HOME/.cargo/env"
}

function __install_binstall() {
  curl -L --proto '=https' --tlsv1.2 -sSf \
    https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh |
    bash
}

__install_rust
__install_binstall

cargo binstall \
  bandwhich \
  bat \
  cargo-audit \
  cargo-bump \
  cargo-edit \
  cargo-machete \
  cargo-nextest \
  cargo-semver-checks \
  cargo-update \
  du-dust \
  exa \
  fastmod \
  fd-find \
  grcov \
  gping \
  hyperfine \
  mergiraf \
  procs \
  rm-improved \
  rustowl \
  sd \
  skim \
  tealdeer \
  tokei \
  topgrade \
  uv \
  xcp \
  xh \
  yazi \
  zoxide \
  --locked -y

rustup component add \
  clippy \
  llvm-tools \
  rustfmt

update_dot_file cargo/config.toml "$HOME/.cargo/config.toml"
